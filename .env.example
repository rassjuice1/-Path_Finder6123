# ===============================================
# Firebase Configuration (Required for Social Login)
# ===============================================
# Get these from Firebase Console → Project Settings → General → Your apps

# Firebase API Key
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here

# Firebase Auth Domain (e.g., your-app.firebaseapp.com)
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Firebase Project ID (from Firebase Console)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Firebase Storage Bucket (e.g., your-project.appspot.com)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Firebase Messaging Sender ID (from Firebase Console → Project Settings)
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789

# Firebase App ID (from Firebase Console → Project Settings → Your apps)
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123def456

# ===============================================
# Google Analytics 4 Configuration (Optional)
# ===============================================
# Get your Property ID from: Google Analytics → Admin → Property Settings → Property ID
NEXT_PUBLIC_GA4_PROPERTY_ID=

# ===============================================
# How to Set Up Firebase Social Login
# ===============================================
# 1. Go to https://console.firebase.google.com
# 2. Create a new project or select existing
# 3. Go to Authentication → Sign-in method
# 4. Enable these providers:
#    - Google
#    - Twitter/X (need Twitter Developer account)
#    - GitHub (need GitHub OAuth app)
#    - LinkedIn (need LinkedIn Developer app)
# 5. Copy your config values from Project Settings → General → Your apps
# 6. Paste values below in .env.local (NOT .env.example)
